# ============================================================
# NGOV2 Environment Configuration Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_NAME=ngov2
DB_USER=root
DB_PASS=your_database_password_here

# --- Application ---
APP_ENV=development
# APP_ENV options: development | production
APP_URL=http://localhost/NGOV2

# --- Security ---
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
PASSWORD_SALT=replace_with_another_long_random_string

# --- Paytm Payment Gateway ---
# Get these from: https://dashboard.paytm.com/next/apikeys
PAYTM_ENV=TEST
# PAYTM_ENV options: TEST | PROD

PAYTM_MID=your_paytm_merchant_id_here
PAYTM_MERCHANT_KEY=your_paytm_merchant_key_here
PAYTM_WEBSITE=WEBSTAGING
# For PROD, change PAYTM_WEBSITE to: DEFAULT

PAYTM_CALLBACK_URL=http://localhost/NGOV2/api/payment-callback.php
# For PROD, change to your live domain:
# PAYTM_CALLBACK_URL=https://sadgurubharadwaja.org/api/payment-callback.php
