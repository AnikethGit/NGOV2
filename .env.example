# ============================================
# NGOV2 Environment Configuration Template
# Copy this file to .env and fill in values.
# NEVER commit .env to GitHub.
# ============================================

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=your_database_password
DB_NAME=ngov2

# App
APP_ENV=development
APP_URL=http://localhost/NGOV2

# Security
JWT_SECRET=change-this-to-a-long-random-string
PASSWORD_SALT=change-this-to-another-random-string

# ---- Paytm Payment Gateway ----
# Get these from: https://dashboard.paytm.com/next/apikeys
PAYTM_ENV=TEST
PAYTM_MID=YOUR_MERCHANT_ID_HERE
PAYTM_MERCHANT_KEY=YOUR_16_CHAR_KEY_HERE
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CALLBACK_URL=http://localhost/NGOV2/api/payment-callback.php

# When going LIVE change to:
# PAYTM_ENV=PROD
# PAYTM_WEBSITE=YOUR_REGISTERED_WEBSITE_NAME
# PAYTM_CALLBACK_URL=https://yourdomain.com/api/payment-callback.php
